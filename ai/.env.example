# mugen-ai environment variables
#
# Copy this file to ~/.config/mugen-ai/.env and fill in the keys for the
# providers you intend to use. Leave a value blank to disable that provider —
# mugen-ai only enables a provider when its key is non-empty.
#
# Ollama runs locally without a key; configure its host in
# ~/.config/mugen-ai/config.toml under [provider.ollama].

# Anthropic Claude — strong tool-calling, ~$5 minimum top-up.
# Key:     https://console.anthropic.com/settings/keys
# Billing: https://console.anthropic.com/settings/billing
ANTHROPIC_API_KEY=

# Google Gemini — generous free tier (10 req/min, 250 req/day).
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI / OpenRouter / LM Studio / vLLM — any OpenAI-compatible endpoint.
# Set [provider.openai].base_url in config.toml to point at OpenRouter,
# a local LM Studio / vLLM server, etc.
# https://platform.openai.com/api-keys
# https://openrouter.ai/keys
OPENAI_API_KEY=

# Optional: override the listen address (default 127.0.0.1:11435).
# MUGEN_AI_PORT=11435
# MUGEN_AI_HOST=127.0.0.1
