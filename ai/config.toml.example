# mugen-ai configuration
#
# Copy to ~/.config/mugen-ai/config.toml. mugen-ai also writes a minimal
# default file on first run, so editing that one in place works too. The
# Yura settings panel in mugen-shell edits this file through the HTTP API
# (GET / PUT /config), and the same panel exposes a "Edit toml" button if
# you'd rather hand-edit.

[personality]
  # Optional auto-header fields. When any of name/tone/language is set,
  # mugen-ai assembles a "You are <name>, a <tone> desktop assistant for
  # mugen-shell." header (plus a "Respond in <language>." line) and
  # prepends it to system_prompt. Leave all three empty to use only
  # system_prompt verbatim. When name is empty (or "Yura") the header
  # also pins a gender-neutral luminous-orb identity so casual tones
  # don't drift to 俺/僕 in Japanese.
  name = "Yura"
  tone = "calm"        # any descriptor: calm / friendly / formal / playful / …
  language = "en"      # ISO 639-1 code; passed straight through to the model
  system_prompt = "You are a helpful desktop assistant. Be concise."

[shell]
  # Quickshell config name used by `qs ipc call` from mugen-ai's tool
  # dispatcher. The mugen-shell default is "mugen-shell"; only change if you
  # run a forked / renamed quickshell config.
  qs_config = "mugen-shell"

# Each [provider.*] block enables that provider, IF its API key env var is
# also set (except ollama, which needs no key). Enable any subset.

[provider.ollama]
  # Local Ollama server. No API key needed.
  host = "http://localhost:11434"

# [provider.google]
#   # Requires GEMINI_API_KEY (or GOOGLE_API_KEY). Legacy single-string
#   # `model` is still honoured as a fallback when `models` is empty.
#   models = ["gemini-2.5-flash", "gemini-2.5-pro"]

# [provider.openai]
#   # OpenAI-compatible endpoint. Requires OPENAI_API_KEY (or local server).
#   base_url = "https://api.openai.com/v1"         # OpenAI itself
#   # base_url = "https://openrouter.ai/api/v1"    # OpenRouter
#   # base_url = "http://localhost:1234/v1"        # LM Studio / vLLM
#   models = []                                     # empty = ask /v1/models

# [provider.anthropic]
#   # Requires ANTHROPIC_API_KEY. Omit `models` to default to claude-haiku-4-5.
#   models = ["claude-haiku-4-5", "claude-sonnet-4-6", "claude-opus-4-7"]

# [tools.app_launch]
#   # Allowlist for the app_launch tool. Yura can only launch commands whose
#   # binary name (basename) appears here. Leave the whole block out to keep
#   # the legacy "anything goes" behaviour — recommended only for single-user
#   # personal setups, since a prompt-injected message could otherwise ask
#   # Yura to run arbitrary commands.
#   allowed_commands = ["firefox", "kitty", "code", "obsidian"]
