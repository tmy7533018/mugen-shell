# mugen-ai configuration
#
# Copy to ~/.config/mugen-ai/config.toml. mugen-ai also writes a minimal
# default file on first run, so editing that one in place works too. The
# Yura settings panel in mugen-shell edits this file through the HTTP API
# (GET / PUT /config), and the same panel exposes a "Edit toml" button if
# you'd rather hand-edit.

[personality]
  # Optional auto-header fields. When any of name/tone/language is set,
  # mugen-ai assembles a "You are <name>, a <tone> desktop assistant for
  # mugen-shell." header (plus a "Respond in <language>." line) and
  # prepends it to system_prompt. Leave all three empty to use only
  # system_prompt verbatim. When name is empty (or "Yura") the header
  # also pins a gender-neutral luminous-orb identity so casual tones
  # don't drift to 俺/僕 in Japanese.
  name = "Yura"
  tone = "calm"        # any descriptor: calm / friendly / formal / playful / …
  language = "en"      # ISO 639-1 code; passed straight through to the model
  system_prompt = "You are a helpful desktop assistant. Be concise."

[shell]
  # Quickshell config name used by `qs ipc call` from mugen-ai's tool
  # dispatcher. The mugen-shell default is "mugen-shell"; only change if you
  # run a forked / renamed quickshell config.
  qs_config = "mugen-shell"
  # Override where mugen-ai looks for cmdTemplate scripts (calendar-cli.py
  # etc.). Defaults to $XDG_CONFIG_HOME/quickshell/mugen-shell/scripts.
  # scripts_dir = "/path/to/scripts"

# Each [provider.*] block enables that provider, IF its API key env var is
# also set (except ollama, which needs no key). Enable any subset.

[provider.ollama]
  # Local Ollama server. No API key needed.
  host = "http://localhost:11434"

# [provider.google]
#   # Requires GEMINI_API_KEY (or GOOGLE_API_KEY). Legacy single-string
#   # `model` is still honoured as a fallback when `models` is empty.
#   models = ["gemini-2.5-flash", "gemini-2.5-pro"]

# [provider.openai]
#   # OpenAI-compatible endpoint. Requires OPENAI_API_KEY (or local server).
#   base_url = "https://api.openai.com/v1"         # OpenAI itself
#   # base_url = "https://openrouter.ai/api/v1"    # OpenRouter
#   # base_url = "http://localhost:1234/v1"        # LM Studio / vLLM
#   models = []                                     # empty = ask /v1/models

# [provider.anthropic]
#   # Requires ANTHROPIC_API_KEY. Omit `models` to default to claude-haiku-4-5.
#   models = ["claude-haiku-4-5", "claude-sonnet-4-6", "claude-opus-4-7"]

# [tools.app_launch]
#   # Strict allowlist for the app_launch tool: Yura can only launch
#   # commands whose binary basename appears here. If the block is omitted
#   # or empty, Yura cannot open any app at all. Pick which installed apps
#   # to allow via Settings → AI / Yura → Allowed apps, or edit by hand:
#   allowed_commands = ["firefox", "kitty", "code", "obsidian"]
#
# [tools]
#   # Categories of tools to hide from Yura (audio / music / brightness /
#   # theme / wallpaper / notification / timer / calendar / panel / app /
#   # memory). Edit via Settings → AI / Yura → Tool categories. Disabling
#   # "memory" also stops saved memories from being shown to the model.
#   disabled_categories = []

# [history]
#   # Auto-delete conversations idle longer than this many days, pruned at
#   # mugen-ai startup. 0 (default) keeps every conversation forever. Edit
#   # via Settings → AI / Yura → Conversation history.
#   retain_days = 0

# [context]
#   # Inject a live desktop-state snapshot (active window, playing media,
#   # volume, unread notifications, running timer, today's events, theme)
#   # into every chat turn as a transient system message, so Yura knows
#   # what's on screen right now. Never stored in conversation history.
#   # Categories hidden via [tools].disabled_categories are excluded from
#   # the snapshot too. Default: on.
#   desktop_state = true

# External Model Context Protocol servers. Each [mcp.servers.<name>] block
# is spawned as a subprocess at startup; its tools are merged into Yura's
# tool set under a "<name>__<tool>" prefix (e.g. memory__read_graph). The
# server name doubles as a tool category, so it can be hidden via
# [tools].disabled_categories above — use a short lowercase name with no
# underscores so that prefix stays unambiguous. A server that fails to
# spawn or handshake is logged and skipped; the rest still load.
#
# A tool that may make an irreversible change is held for a one-tap
# approval in the chat UI before it runs; set `trusted = true` to skip
# that prompt for a server you fully control. `env` values support ${VAR}
# references resolved from mugen-ai's environment, so a token can stay in
# ~/.config/mugen-ai/.env instead of being written here in plaintext.

# [mcp.servers.memory]
#   command = "npx"
#   args = ["-y", "@modelcontextprotocol/server-memory"]
#   # env = { MEMORY_FILE_PATH = "/home/you/.local/state/mugen-ai/memory.json" }
#   # disabled = false   # keep the entry on file but skip spawning it
#   # trusted = false    # true = run this server's tools without an approval prompt

# [mcp.servers.filesystem]
#   command = "npx"
#   args = ["-y", "@modelcontextprotocol/server-filesystem", "/home/you/notes"]

# [mcp.servers.github]
#   command = "npx"
#   args = ["-y", "@modelcontextprotocol/server-github"]
#   env = { GITHUB_TOKEN = "${GITHUB_TOKEN}" }   # ${VAR} from ~/.config/mugen-ai/.env
