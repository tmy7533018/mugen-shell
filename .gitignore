*.mp4
*.webm
*.mkv

# Editor settings
shell/.vscode/

# Stale shell cache dir (real state lives under XDG dirs now)
shell/.cache/

# Python cache
__pycache__/
*.pyc
*.pyo

# Temporary files
*.log
*.tmp

# Backup files
*.bak
*~

# Claude Code local settings
.claude/

# Personal scratchpad
TODO.md
note.txt
MCP_DESIGN.md

# nix build output symlink (anywhere in the tree, since `nix build` drops it
# in the current working directory)
result
result-*

# Per-user hypr overrides, sourced by hyprland.conf but never shipped
system/hypr/configs/user-overrides.conf
