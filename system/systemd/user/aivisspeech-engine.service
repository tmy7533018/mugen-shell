[Unit]
Description=AivisSpeech engine (VOICEVOX-compatible natural TTS for Yura)
After=graphical-session.target
PartOf=graphical-session.target

[Service]
ExecStart=%h/.local/opt/aivisspeech-engine/run --host 127.0.0.1 --port 10101
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
